# Test protocol: TTL barcode in ITI with rpi_camera_ensemble video
# Run verify_rpi_barcode_decoding() after session to check edge decodability.
#
# Wire:
#   Bpod BNC{HARDWARE_BNC_BARCODE} → rpi GPIO TTL-in pin (as configured in rpi ensemble yaml)
#   Bpod BNC{HARDWARE_BNC_TRIAL_START} → ephys digital input (optional reference)

n_max_trials = 20

ttl_identifier_sequence = "sssLss"
ttl_pulse_duration = 0.010

inter_trial_interval = [2, 5, 0.5]
wait_duration = 1.0

#[hardware]
HARDWARE_BNC_TRIAL_START = 1
HARDWARE_BNC_BARCODE = 2

#[barcode]
barcode_bits = 37
barcode_bit_duration_ms = 35.0
barcode_init_duration_ms = 10.0
