[general]
    acquisition_name = "_test_rcc_name_config"     # base name for recording
    remote_data_path = "/home/pi/data/"              # where to store all recordings on RPi
    rpi_username = "pi"
    remote_python_interpreter = "/home/pi/miniconda3/envs/py36/bin/python"      # path to remote python binary
    remote_python_entrypoint = "rpi_camera_colony.acquisition"                  # module to execute
    max_acquisition_time = 7200                                                 # seconds

[log]
    address = "192.168.100.10"
    port = 55555
    level = "DEBUG"
    log_to_console = True
    log_to_file = True
    log_file = "/tmp/some_log_file"

[control]
    address = "192.168.100.10"
    port = 54545

[controllers]
    [[camera_71]]
        description = "top view. behaviour setup #5"

        # General config_data
        address = "192.168.100.71"  # only relevant for dispatching controller start

        stream_video = True
        stream_ip = "192.168.100.71"
        stream_port = 9999

        # TTL config_data
        ttl_in_pin = 16
        ttl_out_pin = 8
        ttl_out_duration = .001

        # Camera properties
        framerate = 60
        resolution = (960, 720)
        color_effects = (128, 128)

    [[camera_72]]
        description = "left face. behaviour setup #2"

        # General config_data
        address = "192.168.100.72"  # only relevant for dispatching controller start

        stream_video = True
        stream_ip = "192.168.100.72"
        stream_port = 9999

        # TTL config_data
        ttl_in_pin = 16
        ttl_out_pin = 8
