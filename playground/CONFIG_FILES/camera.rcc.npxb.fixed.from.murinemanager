    [[camera_73]]
        description = "right face. behaviour setup #2"

        # General config_data
        address = "192.168.100.73"  # only relevant for dispatching controller start

        stream_video = True
        stream_ip = "192.168.100.73"
        stream_port = 9999

        # TTL config_data
        ttl_in_pin = 16
        ttl_out_pin = 8
        ttl_out_duration = .001

        # Camera properties
        framerate = 60
        resolution = (960, 720)
        color_effects = (128, 128)

    [[camera_104]]
        description = "setup: npxb; view: front, top;"

        # General config_data
        address = "192.168.100.104"  # only relevant for dispatching controller start

        stream_video = True
